{
  "ConnectionStrings": {
    "Default": ""
  },
  "Jwt": {
    "Issuer": "PaymentFlow",
    "Audience": "PaymentFlow.Web",
    "Secret": "",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Seed": {
    "DemoPassword": ""
  },
  "ApprovalPolicy": {
    "AutoApproveBelow": 1000,
    "DualApprovalAtOrAbove": 5000
  },
  "Processing": {
    "AutoProcessEnabled": true,
    "PollingIntervalSeconds": 5,
    "BatchSize": 10,
    "SimulatedLatencyMsMin": 750,
    "SimulatedLatencyMsMax": 2500,
    "FailOnCents": 13
  },
  "Compliance": {
    "AutoScreenOnSubmit": true,
    "WatchlistBeneficiaryNames": [ "Gulf Freight" ],
    "WatchlistCountryCodes": [ "IR", "KP", "SY", "CU" ],
    "SinglePaymentReviewLimit": 5000
  },
  "Reconciliation": {
    "IntroduceSyntheticBreaks": true,
    "DropReferenceEndingIn": "4",
    "PhantomAmount": 999.00,
    "AmountDriftMinorUnits": 50
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:4200"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [ { "Name": "Console" } ],
    "Enrich": [ "FromLogContext" ],
    "Properties": { "Application": "PaymentFlow.Api" }
  },
  "AllowedHosts": "*"
}
