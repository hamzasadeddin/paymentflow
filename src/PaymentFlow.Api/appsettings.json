{
  "ConnectionStrings": {
    "Default": ""
  },
  "Jwt": {
    "Issuer": "PaymentFlow",
    "Audience": "PaymentFlow.Web",
    "Secret": "",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Seed": {
    "DemoPassword": ""
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:4200"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [ { "Name": "Console" } ],
    "Enrich": [ "FromLogContext" ],
    "Properties": { "Application": "PaymentFlow.Api" }
  },
  "AllowedHosts": "*"
}
